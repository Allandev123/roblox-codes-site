# Copy to .env.local for local development (Next.js loads it automatically; npm run dev restarts when this file changes).
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables
#
# Replace with values from Supabase → Project Settings → API (non-empty after trim).

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: canonical site URL for metadata / JSON-LD (invalid values fall back to http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: log Supabase games fetch in production builds / server (default: logs in `next dev` only)
# DEBUG_SUPABASE_GAMES=1
#
# Log NEXT_PUBLIC_SUPABASE_URL + raw DATA/ERROR for `games` queries without other verbose logs
# DEBUG_SUPABASE_QUERY=1
#
# When 1, /codes and /codes/[slug] use ONLY Supabase (no static merge from src/data/games.ts)
# NEXT_PUBLIC_SUPABASE_ONLY_CATALOG=1
